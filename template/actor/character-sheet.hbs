<form class="main-form {{cssClass}} {{lang}}">
    <div class="status">{{#if actor.system.isBurnedOut}}
        <span>{{localize 'UA.BurnedOut'}}</span>{{/if}}{{#if actor.system.wounds.severity}}
        <span>{{localize (concat 'UA.' (replace actor.system.wounds.severity ' ' ''))}}</span>{{/if}}
    </div>
    <div class="upper-content">
        <div class="portrait">
            <img data-edit="img" src="{{actor.img}}" alt="{{actor.name}} portrait">
            <button data-action="show-image"><i class="fas fa-image"></i></button>
        </div>
        <div class="upper-content__section">
            <span class="label">{{localize 'UA.Name'}}:</span>
            <input type="text" name="name" value="{{actor.name}}" data-dtype="String">
            <span class="label">{{localize 'UA.Concept'}}:</span>
            <input type="text" name="system.concept" value="{{actor.system.concept}}" data-dtype="String">
            <span class="label">{{localize 'UA.Cabal'}}:</span>
            <select class="cabal" name="system.cabal">{{selectOptions cabalOptions selected=actor.system.cabal}}</select>
            <button data-action="open-cabal" {{disabled (not actor.system.cabal)}}>{{localize 'UA.OpenCabal'}}</button>
        </div>
        <div class="upper-content__section {{#if (not (isGM))}}upper-content__section--wound-threshold-only{{/if}}">
            <span class="label {{#if (isGM)}}label--wrap{{/if}}">{{localize 'UA.WoundThreshold'}}:</span>
            <input type="number" name="system.wounds.threshold" value="{{actor.system.wounds.threshold}}" min="0" data-dtype="Number">{{#if (isGM)}}
            <span class="label">{{localize 'UA.Wounds'}}:</span>
            <input type="number" name="system.wounds.suffered" value="{{actor.system.wounds.suffered}}" min="0" max="{{actor.system.wounds.threshold}}" data-dtype="Number">{{/if}}
        </div>
    </div>
    <nav class="tab-buttons">
        <button data-tab="main">{{localize 'UA.Main'}}</button>
        <button data-tab="identities">{{localize 'UA.Identities'}}</button>
        <button data-tab="magick">{{localize 'UA.Magick'}}</button>
        <button data-tab="items">{{localize 'UA.Items'}}</button>
        <button data-tab="biography">{{localize 'UA.Biography'}}</button>
        <button data-tab="notes">{{localize 'UA.Notes'}}</button>
    </nav>
    <div class="tab-panels">
        <div class="tab lower-content lower-content--2-columns" data-tab="main">
            <div class="lower-content__section obsession-passions">
                <h2>{{localize 'UA.Obsession&Passions'}}:</h2>
                <span class="label">{{localize 'UA.Obsession'}}:</span>
                <input type="text" name="system.obsession" value="{{actor.system.obsession}}" data-dtype="String">
                <span class="label">{{localize 'UA.Used'}}</span>
                {{#each actor.system.passions as |passionData passionName|}}<span class="label">{{localize (concat 'UA.' (capitalize passionName))}}:</span>
                <input type="text" name="system.passions.{{passionName}}.name" value="{{passionData.name}}" data-dtype="String">
                <input type="checkbox" name="system.passions.{{passionName}}.isUsed" {{#if ../actor.system.isBurnedOut}}title="{{localize 'UA.BurnedOut'}}"{{/if}} data-dtype="Boolean" {{checked passionData.isUsed}} {{disabled ../actor.system.isBurnedOut}}>{{/each}}
                <span class="label">{{localize 'UA.FearShockMeter'}}:</span>
                <select name="system.passions.fear.shockMeter">{{selectOptions optionsFearShockMeter selected=actor.system.passions.fear.shockMeter localize=true}}</select>
            </div>
            <div class="lower-content__section relationships">
                <h2>{{localize 'UA.Relationships'}}:</h2>
                {{#each actor.system.relationships as |relationshipData relationshipName|}}<button data-action="roll" data-roll-label="{{localize (concat 'UA.' (capitalize relationshipName))}}{{#if relationshipData.name}} ({{relationshipData.name}}){{/if}}" data-roll-target="{{relationshipData.percentage}}">{{localize (concat 'UA.' (capitalize relationshipName))}}</button>
                <input type="text" name="system.relationships.{{relationshipName}}.name" value="{{relationshipData.name}}" data-dtype="String">
                <input type="number" name="system.relationships.{{relationshipName}}.percentage" value="{{relationshipData.percentage}}" min="0" max="100" step="5" data-dtype="Number">
                <span>%</span>{{/each}}
            </div>
            <div class="lower-content__section lower-content__section--full-width shock-gauge">
                <h2>{{localize 'UA.ShockGauge'}}:</h2>
                {{#each actor.system.shockGauge as |shockMeterData shockMeterName|}}<div class="shock-meter">
                    <div class="shock-meter__name-coerce-resist">
                        <h3>{{localize (concat 'UA.' (capitalize shockMeterName))}}</h3>
                        <p>{{localize (concat 'UA.CoerceWith' (capitalize (shockGaugeSchema shockMeterName 'coerceWith')))}}</p>
                        <p>{{localize (concat 'UA.ResistWith' (capitalize (shockGaugeSchema shockMeterName 'resistWith')))}}</p>
                    </div>
                    <button class="shock-meter__upbeat-ability" data-action="roll" data-roll-label="{{localize (concat 'UA.' (capitalize (shockGaugeSchema shockMeterName 'upbeatAbility')))}}" data-roll-target="{{#each ../actor.system.abilities as |abilityValue abilityName|}}{{#if (equals abilityName (shockGaugeSchema shockMeterName 'upbeatAbility'))}}{{abilityValue}}{{/if}}{{/each}}">{{localize (concat 'UA.' (capitalize (shockGaugeSchema shockMeterName 'upbeatAbility')))}}</button>
                    <div class="shock-meter__hardened-notches">
                        <span class="label">60%</span>
                        <span class="label">55%</span>
                        <span class="label">50%</span>
                        <span class="label">45%</span>
                        <span class="label">40%</span>
                        <span class="label">35%</span>
                        <span class="label">30%</span>
                        <span class="label">25%</span>
                        <span class="label">20%</span>
                        <input type="radio" {{#if (exceeds shockMeterData.notches.hardened 1)}}class="checked"{{/if}} name="system.shockGauge.{{shockMeterName}}.notches.hardened" value="1" {{checked (equals shockMeterData.notches.hardened 1)}}>
                        <input type="radio" {{#if (exceeds shockMeterData.notches.hardened 2)}}class="checked"{{/if}} name="system.shockGauge.{{shockMeterName}}.notches.hardened" value="2" {{checked (equals shockMeterData.notches.hardened 2)}}>
                        <input type="radio" {{#if (exceeds shockMeterData.notches.hardened 3)}}class="checked"{{/if}} name="system.shockGauge.{{shockMeterName}}.notches.hardened" value="3" {{checked (equals shockMeterData.notches.hardened 3)}}>
                        <input type="radio" {{#if (exceeds shockMeterData.notches.hardened 4)}}class="checked"{{/if}} name="system.shockGauge.{{shockMeterName}}.notches.hardened" value="4" {{checked (equals shockMeterData.notches.hardened 4)}}>
                        <input type="radio" {{#if (exceeds shockMeterData.notches.hardened 5)}}class="checked"{{/if}} name="system.shockGauge.{{shockMeterName}}.notches.hardened" value="5" {{checked (equals shockMeterData.notches.hardened 5)}}>
                        <input type="radio" {{#if (exceeds shockMeterData.notches.hardened 6)}}class="checked"{{/if}} name="system.shockGauge.{{shockMeterName}}.notches.hardened" value="6" {{checked (equals shockMeterData.notches.hardened 6)}}>
                        <input type="radio" {{#if (exceeds shockMeterData.notches.hardened 7)}}class="checked"{{/if}} name="system.shockGauge.{{shockMeterName}}.notches.hardened" value="7" {{checked (equals shockMeterData.notches.hardened 7)}}>
                        <input type="radio" {{#if (exceeds shockMeterData.notches.hardened 8)}}class="checked"{{/if}} name="system.shockGauge.{{shockMeterName}}.notches.hardened" value="8" {{checked (equals shockMeterData.notches.hardened 8)}}>
                        <input type="radio" name="system.shockGauge.{{shockMeterName}}.notches.hardened" value="9" {{checked (equals shockMeterData.notches.hardened 9)}}>
                        <span class="label">20%</span>
                        <span class="label">25%</span>
                        <span class="label">30%</span>
                        <span class="label">35%</span>
                        <span class="label">40%</span>
                        <span class="label">45%</span>
                        <span class="label">50%</span>
                        <span class="label">55%</span>
                        <span class="label">60%</span>
                    </div>
                    <button class="shock-meter__downbeat-ability" data-action="roll" data-roll-label="{{localize (concat 'UA.' (capitalize (shockGaugeSchema shockMeterName 'downbeatAbility')))}}" data-roll-target="{{#each ../actor.system.abilities as |abilityValue abilityName|}}{{#if (equals abilityName (shockGaugeSchema shockMeterName 'downbeatAbility'))}}{{abilityValue}}{{/if}}{{/each}}">{{localize (concat 'UA.' (capitalize (shockGaugeSchema shockMeterName 'downbeatAbility')))}}</button>
                    <div class="shock-meter__failed-notches">
                        <a class="label" data-action="reset-failed-notches" data-shock-meter="{{shockMeterName}}">{{localize 'UA.Failed'}}:</a>
                        <input type="radio" {{#if (exceeds shockMeterData.notches.failed 1)}}class="checked"{{/if}} name="system.shockGauge.{{shockMeterName}}.notches.failed" value="1" {{checked (equals shockMeterData.notches.failed 1)}}>
                        <input type="radio" {{#if (exceeds shockMeterData.notches.failed 2)}}class="checked"{{/if}} name="system.shockGauge.{{shockMeterName}}.notches.failed" value="2" {{checked (equals shockMeterData.notches.failed 2)}}>
                        <input type="radio" {{#if (exceeds shockMeterData.notches.failed 3)}}class="checked"{{/if}} name="system.shockGauge.{{shockMeterName}}.notches.failed" value="3" {{checked (equals shockMeterData.notches.failed 3)}}>
                        <input type="radio" {{#if (exceeds shockMeterData.notches.failed 4)}}class="checked"{{/if}} name="system.shockGauge.{{shockMeterName}}.notches.failed" value="4" {{checked (equals shockMeterData.notches.failed 4)}}>
                        <input type="radio" name="system.shockGauge.{{shockMeterName}}.notches.failed" value="5" {{checked (equals shockMeterData.notches.failed 5)}}>
                        <span class="label label--wrap">{{localize 'UA.OngoingMadness'}}:</span>
                        <input type="text" name="system.shockGauge.{{shockMeterName}}.ongoingMadness" value="{{shockMeterData.ongoingMadness}}" data-dtype="String">
                    </div>
                </div>{{/each}}
            </div>
        </div>
        <div class="tab lower-content" data-tab="identities">
            <div class="lower-content__section identities">
                <h2>{{localize 'UA.Identities'}}:</h2>
                <div class="item-list">
                    <ul class="item-list__list">{{#each items as |item itemId|}}{{#if (equals item.type 'identity')}}
                        <li class="item-list__item identity" data-item-id="{{item.id}}">
                            <div class="identity__upper-content">{{#if item.system.type}}
                                <span class="identity__type">{{localize (concat 'UA.' item.system.type 'Identity')}}</span>{{/if}}{{#if (or item.system.isObsession item.system.hasExperience)}}
                                <div class="identity__obsession-experience">{{#if item.system.isObsession}}
                                    <span>{{localize 'UA.Obsession'}}</span>{{/if}}{{#if item.system.hasExperience}}
                                    <span>{{localize 'UA.Experience'}}</span>{{/if}}
                                </div>{{/if}}
                                <div class="identity__name-percentage">
                                    <button data-action="{{#if (equals (setting 'IdentitiesSelectFeatureWhenRolling') 2)}}select-identity-feature{{else}}roll{{/if}}" data-roll-label="{{item.name}}{{#if item.system.type}} ({{localize (concat 'UA.' item.system.type 'Identity')}}){{/if}}" data-roll-target="{{item.system.percentage}}">{{#if (equals (setting 'IdentitiesButtonStyle') 1)}}{{item.name}}{{else}}<i class="fas fa-dice-d10"></i>{{/if}}</button>{{#if (equals (setting 'IdentitiesButtonStyle') 2)}}
                                    <span>{{item.name}}</span>{{/if}}
                                    <span>{{item.system.percentage}}%</span>
                                </div>
                                <div class="identity__edit-delete">
                                    <button data-action="edit-item"><i class="fas fa-edit"></i></button>
                                    <button data-action="delete-item"><i class="fas fa-trash"></i></button>
                                </div>
                            </div>{{#if (or item.system.mundane.ofCourseICan item.system.mundane.substitutesFor item.system.supernatural.ability item.system.avatar.attributes item.system.avatar.symbols item.system.avatar.taboos (and (exceedsOrEquals item.system.percentage 1) item.system.avatar.channels.1-50) (and (exceedsOrEquals item.system.percentage 51) item.system.avatar.channels.51-70) (and (exceedsOrEquals item.system.percentage 71) item.system.avatar.channels.71-90) (and (exceedsOrEquals item.system.percentage 91) item.system.avatar.channels.91-98) (and (exceedsOrEquals item.system.percentage 99) item.system.avatar.channels.99-) item.system.adept.domain item.system.adept.taboos item.system.adept.generateCharge.minor item.system.adept.generateCharge.significant item.system.adept.generateCharge.major item.system.features.one item.system.features.two item.system.details)}}
                            <div class="identity__lower-content">{{#if (and (equals item.system.type 'Mundane') item.system.mundane.ofCourseICan)}}
                                <span class="label">{{localize 'UA.OfCourseICan'}}:</span>
                                <span>{{stripHTML item.system.mundane.ofCourseICan}}</span>{{/if}}{{#if (equals item.system.type 'Avatar')}}{{#if item.system.avatar.attributes}}
                                <span class="label">{{localize 'UA.Attributes'}}:</span>
                                <span>{{stripHTML item.system.avatar.attributes}}</span>{{/if}}{{#if item.system.avatar.symbols}}
                                <span class="label">{{localize 'UA.Symbols'}}:</span>
                                <span>{{stripHTML item.system.avatar.symbols}}</span>{{/if}}{{#if item.system.avatar.taboos}}
                                <span class="label">{{localize 'UA.Taboos'}}:</span>
                                <span>{{stripHTML item.system.avatar.taboos}}</span>{{/if}}{{/if}}{{#if (equals item.system.type 'Adept')}}{{#if item.system.adept.domain}}
                                <span class="label">{{localize 'UA.Domain'}}:</span>
                                <span>{{stripHTML item.system.adept.domain}}</span>{{/if}}{{#if item.system.adept.taboos}}
                                <span class="label">{{localize 'UA.Taboos'}}:</span>
                                <span>{{stripHTML item.system.adept.taboos}}</span>{{/if}}{{#if item.system.adept.generateCharge.minor}}
                                <span class="label">{{localize 'UA.GenerateMinorCharge'}}:</span>
                                <span>{{stripHTML item.system.adept.generateCharge.minor}}</span>{{/if}}{{#if item.system.adept.generateCharge.significant}}
                                <span class="label">{{localize 'UA.GenerateSignificantCharge'}}:</span>
                                <span>{{stripHTML item.system.adept.generateCharge.significant}}</span>{{/if}}{{#if item.system.adept.generateCharge.major}}
                                <span class="label">{{localize 'UA.GenerateMajorCharge'}}:</span>
                                <span>{{stripHTML item.system.adept.generateCharge.major}}</span>{{/if}}{{/if}}
                                {{#each (sortFeatures item) as |feature|}}{{#if feature}}{{#if (equals (setting 'IdentitiesSelectFeatureWhenRolling') 3)}}<button data-action="roll" data-roll-content-header="{{localize (concat 'UA.' (replaceAll (replaceAll feature ' for ' 'For') ' ' ''))}}" data-roll-label="{{item.name}}{{#if item.system.type}} ({{localize (concat 'UA.' item.system.type 'Identity')}}){{/if}}" data-roll-target="{{item.system.percentage}}">{{localize (concat 'UA.' (replaceAll (replaceAll feature ' for ' 'For') ' ' ''))}}</button>{{else}}<span class="label">{{localize (concat 'UA.' (replaceAll (replaceAll feature ' for ' 'For') ' ' ''))}}</span>{{/if}}
                                <span>{{#if (includes feature 'Coerces')}}{{localize 'UA.CoercesMeter_Details'}}{{else}}{{#if (includes feature 'Evaluates')}}{{localize 'UA.EvaluatesMeter_Details'}}{{else}}{{#if (includes feature 'Reads')}}{{localize 'UA.ReadsObsession/Passion_Details'}}{{else}}{{#if (includes feature 'Resists')}}{{localize 'UA.ResistsMeter_Details'}}{{else}}{{#if (includes feature 'Substitutes')}}{{localize 'UA.SubstitutesForAbility_Details'}}{{else}}{{#if (includes feature 'Alter')}}{{localize 'UA.AlterPassion_Details'}}{{else}}{{#if (includes feature 'Harm')}}{{localize 'UA.Harm_Details'}}{{else}}{{#if (includes feature 'Information')}}{{localize 'UA.Information_Details'}}{{else}}{{#if (includes feature 'Protection')}}{{localize 'UA.Protection_Details'}}{{else}}{{#if (includes feature 'Terrorize')}}{{localize 'UA.TerrorizeMeter_Details'}}{{else}}{{#if (includes feature '1-50')}}{{stripHTML item.system.avatar.channels.1-50}}{{else}}{{#if (includes feature '51-70')}}{{stripHTML item.system.avatar.channels.51-70}}{{else}}{{#if (includes feature '71-90')}}{{stripHTML item.system.avatar.channels.71-90}}{{else}}{{#if (includes feature '91-98')}}{{stripHTML item.system.avatar.channels.91-98}}{{else}}{{#if (includes feature '99')}}{{stripHTML item.system.avatar.channels.99-}}{{else}}{{localize (concat 'UA.' (replaceAll feature ' ' '') '_Details')}}{{/if}}{{/if}}{{/if}}{{/if}}{{/if}}{{/if}}{{/if}}{{/if}}{{/if}}{{/if}}{{/if}}{{/if}}{{/if}}{{/if}}{{/if}}</span>{{/if}}{{/each}}{{#if item.system.details}}
                                <span class="label">{{localize 'UA.Details'}}:</span>
                                <span>{{stripHTML item.system.details}}</span>{{/if}}
                            </div>{{/if}}
                        </li>{{/if}}{{/each}}
                    </ul>
                    <div class="item-list__footer">
                        <button data-action="create-item" data-item-type="identity"><i class="fas fa-plus"></i></button>
                    </div>
                </div>
            </div>
        </div>
        <div class="tab lower-content lower-content--2-columns" data-tab="magick">
            <div class="lower-content__section lower-content__section--full-width charges">
                <h2>{{localize 'UA.Charges'}}:</h2>
                <div class="charges__wrapper">
                    {{#each actor.system.charges as |chargeValue chargeName|}}<span class="label label--wrap">{{localize (concat 'UA.' (capitalize chargeName) 'Charges')}}:</span>
                    <input type="number" name="system.charges.{{chargeName}}" value="{{chargeValue}}" min="0" data-dtype="Number">{{/each}}
                </div>
            </div>
            <div class="lower-content__section rituals">
                <h2>{{localize 'UA.Rituals'}}:</h2>
                <div class="item-list">
                    <div class="item-list__header">
                        <div class="item-list__column">
                            <span>{{localize 'UA.Ritual'}}</span>
                        </div>
                        <div class="item-list__column">
                            <span>{{localize 'UA.Cost'}}</span>
                        </div>
                        <button data-action="create-item" data-item-type="ritual"><i class="fas fa-plus"></i></button>
                    </div>
                    <ul class="item-list__list">{{#each items as |item itemId|}}{{#if (equals item.type 'ritual')}}
                        <li class="item-list__item" data-item-id="{{item.id}}">
                            <div class="item-list__column">
                                <span title="{{stripHTML item.system.effect}}">{{item.name}}</span>
                            </div>
                            <div class="item-list__column">
                                <span>{{item.system.cost.amount}}{{#if item.system.cost.type}}{{localize (concat 'UA.' (replace item.system.cost.type ' ' '') '_Abbreviation')}}{{/if}}</span>
                            </div>
                            <div class="item-list__column">
                                <button data-action="post-item"><i class="fas fa-message"></i></button>
                                <button data-action="edit-item"><i class="fas fa-edit"></i></button>
                                <button data-action="delete-item"><i class="fas fa-trash"></i></button>
                            </div>
                        </li>{{/if}}{{/each}}
                    </ul>
                </div>
            </div>
            <div class="lower-content__section spells">
                <h2>{{localize 'UA.Spells'}}:</h2>
                <div class="item-list">
                    <div class="item-list__header">
                        <div class="item-list__column">
                            <span>{{localize 'UA.Spell'}}</span>
                        </div>
                        <div class="item-list__column">
                            <span>{{localize 'UA.Cost'}}</span>
                        </div>
                        <button data-action="create-item" data-item-type="spell"><i class="fas fa-plus"></i></button>
                    </div>
                    <ul class="item-list__list">{{#each items as |item itemId|}}{{#if (equals item.type 'spell')}}
                        <li class="item-list__item" data-item-id="{{item.id}}">
                            <div class="item-list__column">
                                <span title="{{stripHTML item.system.effect}}">{{item.name}}</span>
                            </div>
                            <div class="item-list__column">
                                <span>{{item.system.cost.amount}}{{#if item.system.cost.type}}{{localize (concat 'UA.' (replace item.system.cost.type ' ' '') '_Abbreviation')}}{{/if}}</span>
                            </div>
                            <div class="item-list__column">
                                <button data-action="post-item"><i class="fas fa-message"></i></button>
                                <button data-action="edit-item"><i class="fas fa-edit"></i></button>
                                <button data-action="delete-item"><i class="fas fa-trash"></i></button>
                            </div>
                        </li>{{/if}}{{/each}}
                    </ul>
                </div>
            </div>
        </div>
        <div class="tab lower-content lower-content--2-columns" data-tab="items">
            <div class="lower-content__section artifacts">
                <h2>{{localize 'UA.Artifacts'}}:</h2>
                <div class="item-list">
                    <div class="item-list__header">
                        <div class="item-list__column">
                            <span>{{localize 'UA.Artifact'}}</span>
                        </div>
                        <div class="item-list__column">
                            <span>{{localize 'UA.Charges'}}</span>
                        </div>
                        <button data-action="create-item" data-item-type="artifact"><i class="fas fa-plus"></i></button>
                    </div>
                    <ul class="item-list__list">{{#each items as |item itemId|}}{{#if (equals item.type 'artifact')}}
                        <li class="item-list__item" data-item-id="{{item.id}}">
                            <div class="item-list__column">
                                <span title="{{stripHTML item.system.effect}}">{{item.name}}</span>
                            </div>
                            <div class="item-list__column">
                                <span>{{#if item.system.charges.isHidden}}&quest;{{else}}{{#if item.system.charges.isEternal}}&infin;{{else}}{{item.system.charges.amount}}{{/if}}{{/if}}</span>
                            </div>
                            <div class="item-list__column">
                                <button data-action="post-item"><i class="fas fa-message"></i></button>
                                <button data-action="edit-item"><i class="fas fa-edit"></i></button>
                                <button data-action="delete-item"><i class="fas fa-trash"></i></button>
                            </div>
                        </li>{{/if}}{{/each}}
                    </ul>
                </div>
            </div>
            <div class="lower-content__section items">
                <h2>{{localize 'UA.OtherItems'}}:</h2>
                <div class="item-list">
                    <div class="item-list__header">
                        <div class="item-list__column">
                            <span>{{localize 'UA.Item'}}</span>
                        </div>
                        <button data-action="create-item" data-item-type="item"><i class="fas fa-plus"></i></button>
                    </div>
                    <ul class="item-list__list">{{#each items as |item itemId|}}{{#if (equals item.type 'item')}}
                        <li class="item-list__item" data-item-id="{{item.id}}">
                            <div class="item-list__column">
                                <span title="{{stripHTML item.system.effect}}">{{item.name}}</span>
                            </div>
                            <div class="item-list__column">
                                <button data-action="post-item"><i class="fas fa-message"></i></button>
                                <button data-action="edit-item"><i class="fas fa-edit"></i></button>
                                <button data-action="delete-item"><i class="fas fa-trash"></i></button>
                            </div>
                        </li>{{/if}}{{/each}}
                    </ul>
                </div>
            </div>
        </div>
        <div class="tab lower-content" data-tab="biography">
            <div class="lower-content__section">
                <h2>{{localize 'UA.Appearance'}}:</h2>
                {{editor enrichedAppearance target="system.appearance" engine="prosemirror" button=true class="editor-content--small"}}
            </div>
            <div class="lower-content__section">
                <h2>{{localize 'UA.Personality'}}:</h2>
                {{editor enrichedPersonality target="system.personality" engine="prosemirror" button=true class="editor-content--small"}}
            </div>
            <div class="lower-content__section">
                <h2>{{localize 'UA.Background'}}:</h2>
                {{editor enrichedBackground target="system.background" engine="prosemirror" button=true class="editor-content--small"}}
            </div>
        </div>
        <div class="tab lower-content" data-tab="notes">
            <div class="lower-content__section">
                <h2>{{localize 'UA.PublicNotes'}}:</h2>
                {{editor enrichedPublicNotes target="system.notes.public" engine="prosemirror" button=true class="editor-content--large"}}
            </div>
            <div class="lower-content__section">
